# Minimal JSON-like subset: numbers, lowercase-letter string tokens,
# nested objects and arrays. The string regex is intentionally narrow
# so the grammar stays easy to exercise.
<value>  ::= /[0-9]+/ | /"[a-z]+"/ | <object> | <array>
<object> ::= "{" ( <member> ( "," <member> )* )? "}"
<member> ::= /"[a-z]+"/ ":" <value>
<array>  ::= "[" ( <value> ( "," <value> )* )? "]"
